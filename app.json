{
  "expo": {
    "name": "VShop",
    "slug": "vshop",
    "version": "3.1.2",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vshop",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://u.expo.dev/90bdf4e2-2472-4cd1-a168-4a5ee4e62218",
      "checkAutomatically": "ON_ERROR_RECOVERY"
    },
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f343b"
    },
    "ios": {
      "bundleIdentifier": "dev.vasc.vshop",
      "buildNumber": "29",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2f343b"
      },
      "permissions": [
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ],
      "package": "dev.vasc.vshop2",
      "versionCode": 74
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-updates",
      [
        "expo-dev-launcher",
        {
          "launchMode": "most-recent"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#7b838f"
        }
      ],
      "react-native-background-fetch"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "90bdf4e2-2472-4cd1-a168-4a5ee4e62218"
      },
      "router": {
        "origin": false
      }
    },
    "owner": "hyeon004"
  }
}
